│   │   └── Requests/           # Form request validation
│   ├── Models/                 # Eloquent models
│   │   ├── User.php
│   │   ├── Workout.php
│   │   ├── WorkoutMove.php
│   │   ├── UserWorkout.php
│   │   ├── Streak.php
